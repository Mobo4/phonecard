PORT=3000
NODE_ENV=development

# Supabase (Google auth managed by Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
REQUIRE_CHECKOUT_AUTH=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Telnyx
TELNYX_API_KEY=
TELNYX_WEBHOOK_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=

# Controls
MIN_CONNECT_SECONDS=60
SAFETY_BUFFER_SECONDS=5

# Redis (throttling/cooldown when wired in production)
REDIS_URL=
REDIS_TOKEN=

# Postgres (persistent adapter)
DATABASE_URL=
